# Enforce Unix LF line endings for all text files.
# Critical: git apply requires LF — CRLF causes "corrupt patch" errors.
* text=auto eol=lf

# Explicitly LF
*.py        text eol=lf
*.sh        text eol=lf
*.bash      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.json      text eol=lf
*.env*      text eol=lf
*.dockerfile text eol=lf
Dockerfile  text eol=lf
Makefile    text eol=lf
*.patch     text eol=lf

# PowerShell — keep CRLF on Windows checkouts
*.ps1       text eol=crlf
*.psm1      text eol=crlf
*.psd1      text eol=crlf

# Binary — no line ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.gguf      binary
*.bin       binary
*.safetensors binary