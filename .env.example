# ============================================================
# AI CODING AGENT FACTORY — CONFIGURATION
# ============================================================
# Copy to .env and edit for your hardware.
#
# Profiles:
#   gpu         → Multi-GPU server (separate model per role)
#   gpu-shared  → Single GPU (one model, all roles)
#   laptop      → CPU/small GPU (Ollama)
# ============================================================

PROFILE=gpu

# ── HuggingFace (for gated models) ──
HF_TOKEN=hf_your_token_here

# ── Project Path (bind-mounted into executor + orchestrator) ──
PROJECT_PATH=/path/to/your/project

# ── Multi-GPU Models ──
CODER_MODEL=Qwen/Qwen3-Coder-Next-80B-A3B-Instruct
CODER_GPU=0
CODER_TP=1
CODER_CTX=32768

ARCHITECT_MODEL=Qwen/Qwen3.5-35B-A3B
ARCHITECT_GPU=1
ARCHITECT_TP=1
ARCHITECT_CTX=65536

REVIEWER_MODEL=Qwen/QwQ-32B
REVIEWER_GPU=2
REVIEWER_TP=1
REVIEWER_CTX=32768

# ── Single-GPU Shared Model ──
SHARED_MODEL=Qwen/Qwen3-Coder-Next-80B-A3B-Instruct
SHARED_CTX=32768
# Uncomment for gpu-shared profile:
# CODER_ENDPOINT=http://vllm-shared:8000/v1
# ARCHITECT_ENDPOINT=http://vllm-shared:8000/v1
# REVIEWER_ENDPOINT=http://vllm-shared:8000/v1

# ── Laptop ──
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_EMBED=nomic-embed-text

# ── Embedding ──
EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B

# ── Orchestrator Config ──
MAX_DEBATE_ROUNDS=3
MAX_CONTEXT_TOKENS=24000
MAX_AGENT_RUNTIME=300

# ── Executor Config ──
CMD_TIMEOUT=120
EXECUTOR_MEM_LIMIT=2g
EXECUTOR_CPUS=2
ALLOWED_CMDS=pytest,npm,node,cargo,go,make,git,bash,sh,cat,ls,find,grep

# ── Ports ──
ORCHESTRATOR_PORT=9000
EXECUTOR_PORT=9001
VLLM_CODER_PORT=8001
VLLM_ARCHITECT_PORT=8002
VLLM_REVIEWER_PORT=8003
VLLM_SHARED_PORT=8001
OLLAMA_PORT=11434
CHROMA_PORT=8100
REDIS_PORT=6379
WEBUI_PORT=3000

# ── Phase 3.3: GitHub webhook ─────────────────────────────────────────────────
# Set in GitHub repo → Settings → Webhooks → Secret
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
# PAT with: repo:read, actions:read, issues:read
GITHUB_TOKEN=ghp_your_token_here
# Format: owner/repo (e.g. harshd42/ai-coding-agent-factory)
GITHUB_REPO=your-github-username/your-repo-name

# ── Phase 3.4: Failure pattern learning ──────────────────────────────────────
# Number of similar failures before an anti-pattern skill is auto-extracted
N_FAILURES_THRESHOLD=3

# ── Phase 3.2: Fine-tune data collection ─────────────────────────────────────
# Path inside the orchestrator container where training JSONL is written
TRAINING_DATA_PATH=/app/memory/training_data.jsonl